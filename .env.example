# ==============================================
# chanvip.skills — 环境配置模板
# 复制此文件，重命名为 .env，填入你的配置
# ==============================================

# -------- 大模型配置（必填，任选其一）--------

# 【推荐】通义千问（中文效果好，有免费额度）
# 获取地址: https://dashscope.console.aliyun.com/
TONGYI_API_KEY=sk-xxxxxxxxxxxxxxxx
TONGYI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
TONGYI_MODEL=qwen-plus
DEFAULT_MODEL=tongyi

# 智谱AI
# ZHIPUAI_API_KEY=your_zhipuai_key
# DEFAULT_MODEL=zhipuai

# OpenAI（需要科学上网）
# OPENAI_API_KEY=sk-xxx
# DEFAULT_MODEL=openai

# -------- 向量模型配置（一般不需改）--------
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# -------- 知识库配置（一般不需改）--------
KNOWLEDGE_DIR=./knowledge
INDEX_PATH=./knowledge/index.faiss
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=4

# -------- Web 服务配置--------
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_DEBUG=false

# -------- 日志配置--------
LOG_LEVEL=INFO
LOG_FILE=./chanvip.log
